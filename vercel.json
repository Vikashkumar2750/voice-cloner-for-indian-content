{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/analyze-voice",
      "dest": "backend/api/analyze-voice.ts"
    },
    {
      "src": "/api/localize-script",
      "dest": "backend/api/localize-script.ts"
    },
    {
      "src": "/api/clone-synthesize",
      "dest": "backend/api/clone-synthesize.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/index.html"
    }
  ]
}
